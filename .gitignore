# --- Virtual Environment ---
# This is the folder containing your installed libraries (pip install)
# Never upload this; others will run 'pip install' themselves.
env/
venv/
.venv/
ENV/

# --- Environment Variables ---
# CRITICAL: This contains your DB password and JWT Secret Key. 
# NEVER commit this to Git.
.env

# --- Python Cache ---
# Temporary files created by Python when running your code
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.cache/

# --- Operating System Files ---
# Junk files created by Windows or macOS
.DS_Store
Thumbs.db

# --- IDE Settings ---
# Settings specific to your VS Code
.vscode/
.idea/
*.swp
*.swo

# --- Distribution / Build ---
# Only needed if you package your app
dist/
build/
*.egg-info/