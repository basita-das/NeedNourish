# --- Virtual Environment (Python) ---
env/
venv/
.venv/
ENV/

# --- Environment Variables (Backend & Frontend) ---
# This ignores the .env in the root AND inside the client folder
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Python Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.cache/

# --- Frontend (Node/Vite) ---
# Never upload the thousands of small library files in node_modules
node_modules/
client/node_modules/

# Production build folder (the compiled frontend)
dist/
client/dist/

# Vite/TS log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --- Operating System Files ---
.DS_Store
Thumbs.db

# --- IDE Settings ---
.vscode/
.idea/
*.swp
*.swo

# --- Local Databases ---
# If you ever use SQLite for testing
*.sqlite3
*.db